#include <iostream>
#include <cstdlib>
#include <ctime>

using namespace std;  // Brings std namespace into scope for shorter code [web:1]

int main() {
    srand(static_cast<unsigned>(time(nullptr)));  // Seed random number generator [web:2][web:3]

    int secretNumber = rand() % 100 + 1;  // Generate random number between 1 and 100 [web:2][web:3]
    
    int guess;
    cout << "Guess the number (1-100): ";
    cin >> guess;  // Prompt and read user guess [web:2]

    if (guess == secretNumber) {
        cout << "Correct! The number was " << secretNumber << "." << endl;
    } else {
        cout << "Wrong. The number was " << secretNumber << "." << endl;
    }

    return 0;
}
